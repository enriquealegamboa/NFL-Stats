PORT=8080
CORS_ORIGIN=http://localhost:3000

# Supabase Postgres connection for Spring Data JPA.
# Get these from the Supabase dashboard:
#   Project Settings -> Database -> Connection string -> JDBC
# Leave blank until you add JPA entities; the app starts without a database.
SUPABASE_DB_URL=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
